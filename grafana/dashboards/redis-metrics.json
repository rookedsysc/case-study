{
  "title": "Redis Metrics",
  "uid": "redis-metrics",
  "tags": ["redis", "cache"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "메모리 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used Memory"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "Max Memory"
        },
        {
          "expr": "redis_memory_used_rss_bytes",
          "legendFormat": "RSS Memory"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 2,
      "title": "메모리 Fragmentation Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "redis_mem_fragmentation_ratio",
          "legendFormat": "Fragmentation Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "연결된 클라이언트 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected Clients"
        },
        {
          "expr": "redis_blocked_clients",
          "legendFormat": "Blocked Clients"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "키 개수 및 Eviction",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(redis_db_keys)",
          "legendFormat": "Total Keys"
        },
        {
          "expr": "rate(redis_evicted_keys_total[5m])",
          "legendFormat": "Evictions/s"
        },
        {
          "expr": "rate(redis_expired_keys_total[5m])",
          "legendFormat": "Expired/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "명령어 처리 통계",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[5m])",
          "legendFormat": "Commands/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "Hit/Miss 비율",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
          "legendFormat": "Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "가용성 및 포화도",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "up{job=\"redis-exporter\"} * 100",
          "legendFormat": "Exporter Up %"
        },
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
          "legendFormat": "Memory Usage %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Rejected Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(redis_rejected_connections_total[5m])",
          "legendFormat": "Rejected/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 9,
      "title": "요청 적체 신호",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "redis_blocked_clients",
          "legendFormat": "Blocked Clients"
        },
        {
          "expr": "rate(redis_rejected_connections_total[1m])",
          "legendFormat": "Rejected Connections/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "순간 처리량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "redis_instantaneous_ops_per_sec",
          "legendFormat": "Instantaneous Ops/s"
        },
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "Processed Commands/s (1m)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 11,
      "title": "네트워크 처리량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total[1m])",
          "legendFormat": "Input Bytes/s"
        },
        {
          "expr": "rate(redis_net_output_bytes_total[1m])",
          "legendFormat": "Output Bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 12,
      "title": "연결 압력",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected Clients"
        },
        {
          "expr": "rate(redis_rejected_connections_total[1m])",
          "legendFormat": "Rejected Connections/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ],
  "schemaVersion": 38,
  "version": 3
}
