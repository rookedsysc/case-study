{
  "title": "NGINX Metrics",
  "uid": "nginx-metrics",
  "tags": ["nginx", "proxy", "infrastructure"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Exporter 상태",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"nginx-exporter\"} * 100",
          "legendFormat": "Exporter Up - {{instance}}"
        },
        {
          "expr": "nginx_up * 100",
          "legendFormat": "NGINX Scrape Up - {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP 요청 처리량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total[1m])",
          "legendFormat": "Requests/s - {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "활성 연결 상태",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "nginx_connections_active",
          "legendFormat": "Active - {{instance}}"
        },
        {
          "expr": "nginx_connections_waiting",
          "legendFormat": "Waiting - {{instance}}"
        },
        {
          "expr": "nginx_connections_reading",
          "legendFormat": "Reading - {{instance}}"
        },
        {
          "expr": "nginx_connections_writing",
          "legendFormat": "Writing - {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "연결 처리량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(nginx_connections_accepted[1m])",
          "legendFormat": "Accepted/s - {{instance}}"
        },
        {
          "expr": "rate(nginx_connections_handled[1m])",
          "legendFormat": "Handled/s - {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 5,
      "title": "애플리케이션 5xx 응답률",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (instance)",
          "legendFormat": "App 5xx/s - {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "Nginx Upstream 이상 징후",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "(1 - nginx_up) * 100",
          "legendFormat": "Stub Status Scrape Failure % - {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
