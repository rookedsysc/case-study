{
  "title": "Application Logs",
  "uid": "application-logs",
  "tags": ["logs", "loki", "application"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "로그 볼륨",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({service_name=~\".+\"}[1m])) by (detected_level)",
          "legendFormat": "{{detected_level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "에러 로그 비율",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({service_name=~\".+\"} |~ \"(?i)(error|exception|fail)\" [5m]))",
          "legendFormat": "error logs/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 3,
      "title": "로그 무수집 탐지",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "absent_over_time({service_name=~\".+\"}[5m])",
          "legendFormat": "absent"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "ERROR 로그",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\".+\"} |~ \"(?i)(error|exception|fail)\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 5,
      "title": "전체 로그",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 24 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\".+\"}",
          "legendFormat": ""
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 2
}
