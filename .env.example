# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=casestudy
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
# Docker 내부에서 앱이 MySQL에 연결할 때 사용하는 포트
MYSQL_PORT=3306
# localhost에서 MySQL에 접속할 때 사용하는 포트
MYSQL_HOST_PORT=3306

# Redis
# Docker 내부에서 앱이 Redis에 연결할 때 사용하는 포트
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
# localhost에서 Redis 단일 인스턴스에 접속할 때 사용하는 포트
REDIS_HOST_PORT=6379
# localhost에서 Redis Cluster Proxy에 접속할 때 사용하는 포트
REDIS_CLUSTER_PROXY_HOST_PORT=7777

# App
APP_PORT=8080

# Nginx
NGINX_HOST_PORT=80

# Observability
GRAFANA_HOST_PORT=3000
PROMETHEUS_HOST_PORT=9090
LOKI_HOST_PORT=3100
OTEL_GRPC_HOST_PORT=4317
OTEL_HTTP_HOST_PORT=4318
OTEL_PROMETHEUS_HOST_PORT=8889
MYSQLD_EXPORTER_HOST_PORT=9104
REDIS_EXPORTER_HOST_PORT=9121
