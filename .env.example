# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=casestudy
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
# Docker 내부에서 앱이 MySQL에 연결할 때 사용하는 포트
MYSQL_PORT=3306
# localhost에서 MySQL에 접속할 때 사용하는 포트
MYSQL_HOST_PORT=33306

# Redis
# Docker 내부에서 앱이 Redis에 연결할 때 사용하는 포트
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
# localhost에서 Redis 단일 인스턴스에 접속할 때 사용하는 포트
REDIS_HOST_PORT=36379
# localhost에서 Redis Cluster Proxy에 접속할 때 사용하는 포트
REDIS_CLUSTER_PROXY_HOST_PORT=37777

# App
APP_PORT=8080

# Nginx
NGINX_HOST_PORT=38080

# Observability
GRAFANA_HOST_PORT=33001
PROMETHEUS_HOST_PORT=39090
LOKI_HOST_PORT=33100
OTEL_GRPC_HOST_PORT=34317
OTEL_HTTP_HOST_PORT=34318
OTEL_PROMETHEUS_HOST_PORT=38889
MYSQLD_EXPORTER_HOST_PORT=39104
REDIS_EXPORTER_HOST_PORT=39121
