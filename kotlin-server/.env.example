# IDEA 로컬 실행용 환경변수 (docker compose로 인프라 띄운 후 사용)
# IntelliJ Run Configuration의 EnvFile 플러그인 또는 .env 파일로 로드

# MySQL (docker-compose의 MYSQL_PORT, MYSQL_DATABASE, MYSQL_USER, MYSQL_PASSWORD와 일치시킬 것)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/casestudy
SPRING_DATASOURCE_USERNAME=appuser
SPRING_DATASOURCE_PASSWORD=apppassword

# Redis (docker-compose의 REDIS_PORT, REDIS_PASSWORD와 일치시킬 것)
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=redispassword
