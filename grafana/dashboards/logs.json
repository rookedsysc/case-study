{
  "title": "Application Logs",
  "uid": "application-logs",
  "tags": ["logs", "loki", "application"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "로그 볼륨",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({service_name=~\".+\"}[1m])) by (detected_level)",
          "legendFormat": "{{detected_level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "ERROR 로그",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\".+\"} |~ \"(?i)(error|exception|fail)\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 3,
      "title": "전체 로그",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 18 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\".+\"}",
          "legendFormat": ""
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
