# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=casestudy
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
# Docker 내부에서 앱이 ProxySQL을 통해 MySQL에 연결할 때 사용하는 호스트/포트
MYSQL_HOST=proxysql
MYSQL_PORT=6033
MYSQL_WRITE_HOST=proxysql
MYSQL_WRITE_PORT=6033
MYSQL_READ_HOST=proxysql
MYSQL_READ_PORT=6033
# localhost에서 ProxySQL에 접속할 때 사용하는 포트
PROXYSQL_HOST_PORT=36033
# localhost에서 ProxySQL Admin에 접속할 때 사용하는 포트
PROXYSQL_ADMIN_HOST_PORT=36032
# localhost에서 Source MySQL에 접속할 때 사용하는 포트
MYSQL_SOURCE_HOST_PORT=33306
# localhost에서 Replica MySQL에 접속할 때 사용하는 포트
MYSQL_REPLICA_HOST_PORT=3307

# Redis
# Docker 내부에서 앱이 Redis에 연결할 때 사용하는 포트
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
# localhost에서 Redis 단일 인스턴스에 접속할 때 사용하는 포트
REDIS_HOST_PORT=36379
# localhost에서 Redis Cluster Proxy에 접속할 때 사용하는 포트
REDIS_CLUSTER_PROXY_HOST_PORT=37777

# App
APP_PORT=8080
# true로 설정하면 모든 쿼리가 Source(Write)로 라우팅 (Replica 없이 테스트할 때 사용)
MYSQL_SOURCE_ONLY=false

# Nginx
NGINX_HOST_PORT=38080

# Observability
GRAFANA_HOST_PORT=33001
PROMETHEUS_HOST_PORT=39090
LOKI_HOST_PORT=33100
OTEL_GRPC_HOST_PORT=34317
OTEL_HTTP_HOST_PORT=34318
OTEL_PROMETHEUS_HOST_PORT=38889
MYSQLD_EXPORTER_HOST_PORT=39104
REDIS_EXPORTER_HOST_PORT=39121
